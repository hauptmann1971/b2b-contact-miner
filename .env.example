# Database
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/contact_miner

# Redis
REDIS_URL=redis://localhost:6379/0

# Choose ONE SERP provider
SERP_API_PROVIDER=serpapi
SERPAPI_KEY=your_serpapi_key_here

# Alternative providers (comment out if not using)
# BRIGHTDATA_API_KEY=your_brightdata_key
# SCRAPERAPI_KEY=your_scraperapi_key

# LLM (optional)
OPENAI_API_KEY=your_openai_key
USE_LLM_EXTRACTION=false

# Crawler
MAX_PAGES_PER_DOMAIN=10
CONCURRENT_BROWSERS=5
HEADLESS_BROWSER=true
MAX_CONCURRENT_DOMAINS_PER_SITE=5

# Rate limiting
DELAY_BETWEEN_REQUESTS=1.0
MAX_RETRIES=3

# Pipeline Settings
SEARCH_RESULTS_PER_KEYWORD=5
MAX_KEYWORDS_PER_RUN=50

# Logging
LOG_FORMAT=text
LOG_LEVEL=INFO

# Security
SECRET_KEY=  # Оставьте пустым для автоматической генерации или укажите свой ключ
