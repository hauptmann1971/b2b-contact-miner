# Database
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/contact_miner

# Redis
REDIS_URL=redis://localhost:6379/0

# Choose ONE SERP provider (duckduckgo = free; serpapi/google for production)
SERP_API_PROVIDER=duckduckgo
SERPAPI_KEY=your_serpapi_key_here

# Alternative providers (comment out if not using)
# BRIGHTDATA_API_KEY=your_brightdata_key
# SCRAPERAPI_KEY=your_scraperapi_key

# LLM (optional)
OPENAI_API_KEY=your_openai_key
USE_LLM_EXTRACTION=true
USE_LLM_DOMAIN_CLASSIFICATION=false
SAVE_EMPTY_DOMAIN_CONTACTS=false

# YandexGPT (optional, for autonomous nightly runs)
USE_YANDEXGPT=false
YANDEX_FOLDER_ID=your_yandex_folder_id
YANDEX_IAM_TOKEN=your_yandex_iam_token
# OAuth token used to auto-refresh IAM before pipeline start:
YANDEX_OAUTH_TOKEN=your_yandex_oauth_token
AUTO_REFRESH_YANDEX_IAM_BEFORE_RUN=false
PERSIST_REFRESHED_YANDEX_IAM_TO_ENV=false
ENFORCE_LLM_READY=false
LLM_HEALTHCHECK_BEFORE_RUN=true
LLM_HEALTHCHECK_TIMEOUT_SECONDS=10

# SERP snippet: skip Playwright when title/snippet already has email or Telegram
SERP_SNIPPET_SKIP_CRAWL=true
# Auto-suggest denylist: min zero-page crawls per host in SERP_DENYLIST_LOOKBACK_DAYS
SERP_DENYLIST_LOOKBACK_DAYS=7
SERP_DENYLIST_MIN_ZERO_CRAWLS=3

# Crawler (HTTP-first, then Playwright)
HTTP_FETCH_ENABLED=true
HTTP_FETCH_TIMEOUT=8
HTTP_FETCH_MIN_TEXT_CHARS=200
MAX_PAGES_PER_DOMAIN=3
CRAWL_WAIT_UNTIL=domcontentloaded
REQUEST_TIMEOUT=12
REQUEST_TIMEOUT_FALLBACK=18
DOMAIN_CRAWL_TIMEOUT=50
CONCURRENT_BROWSERS=3
HEADLESS_BROWSER=true
MAX_CONCURRENT_DOMAINS_PER_SITE=3

# Rate limiting
DELAY_BETWEEN_REQUESTS=1.0
MAX_RETRIES=3

# Pipeline Settings
SEARCH_RESULTS_PER_KEYWORD=5
MAX_KEYWORDS_PER_RUN=50

# Logging
LOG_FORMAT=text
LOG_LEVEL=INFO
FLASK_DEBUG=false
NIGHTLY_FAIL_ON_QUALITY_GATE=false

# Optional admin auth for /admin, /llm-data and protected admin APIs
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Security
SECRET_KEY=  # Оставьте пустым для автоматической генерации или укажите свой ключ
